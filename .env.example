# =============================================================================
#  TenderMania — environment template
# =============================================================================
#  1. Copy this file to .env:    cp .env.example .env
#  2. Fill in OPENAI_API_KEY (required) — everything else has working defaults.
#  3. Telegram + SMTP are optional. Without them, drafts still persist in
#     SQLite and you can approve via the CLI (`python3 -m sponsorus.scripts.approve`).
# =============================================================================

# --- LLM (REQUIRED) ----------------------------------------------------------
#  Any OpenAI-compatible endpoint works. Two common setups:
#
#  (a) Public OpenAI:
OPENAI_API_KEY=sk-REPLACE_ME
SPONSORUS_LLM_BASE_URL=https://api.openai.com/v1
SPONSORUS_LLM_MODEL=gpt-4o-mini
#
#  (b) Local 9router gateway (what we used during the build):
# OPENAI_API_KEY=sk-9router-local
# SPONSORUS_LLM_BASE_URL=http://localhost:20128/v1
# SPONSORUS_LLM_MODEL=cx/gpt-5.5

# --- Pipeline knobs (all optional) -------------------------------------------
SOURCES=lpse,worldbank      # comma-separated: lpse | worldbank | both
MAX_TENDERS=6                # how many to process per run
PREFER_LIVE=true             # true = hit live APIs; false = use bundled fixtures
SCORE_THRESHOLD=55           # weighted-score cutoff for PURSUE
PUSH_TELEGRAM=false          # true to send approval cards to Telegram
DRY_RUN=true                 # true = print email instead of sending

# --- Telegram approval gate (OPTIONAL) ---------------------------------------
#  Skip these and use the CLI: python3 -m sponsorus.scripts.approve
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_OPERATOR_CHAT_ID=123456789

# --- Real email send (OPTIONAL — only if you set DRY_RUN=false) --------------
# SMTP_USER=you@gmail.com
# SMTP_APP_PASSWORD=app-password-from-google
